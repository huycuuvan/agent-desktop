{
  "name": "desktop-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/presentation/cli/index.ts",
    "snapshot:latest": "tsx src/presentation/cli/snapshotLatest.ts",
    "snapshot:diff": "tsx src/presentation/cli/snapshotDiff.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/presentation/cli/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "dotenv": "^16.4.5",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.47.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
